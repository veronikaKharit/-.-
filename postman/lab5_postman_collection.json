              "    throw new Error('sessionId is empty. Request 4 must run successfully before request 5.');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Get session returns 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    pm.test('Returned session matches saved id', function () {",
              "        pm.expect(jsonData.id).to.eql(pm.environment.get('sessionId'));",
              "    });",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "6. Send answer",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"answerText\": \"Предлагаю выгодные условия и уточняю ваши потребности\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/sessions/{{sessionId}}/answer",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "sessions",
            "{{sessionId}}",
            "answer"
          ]
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var sessionId = pm.environment.get('sessionId');",
              "if (!sessionId) {",
              "    throw new Error('sessionId is empty. Request 4 must run successfully before request 6.');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Send answer returns 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    pm.test('Send answer returns a non-empty object', function () {",
              "        pm.expect(jsonData).to.be.an('object');",
              "        pm.expect(Object.keys(jsonData).length).to.be.above(0);",
              "    });",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "7. Finish session",
      "request": {
        "method": "PUT",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/sessions/{{sessionId}}/finish",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "sessions",
            "{{sessionId}}",
            "finish"
          ]
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var sessionId = pm.environment.get('sessionId');",
              "if (!sessionId) {",
              "    throw new Error('sessionId is empty. Request 4 must run successfully before request 7.');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Finish session returns 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    var body = JSON.stringify(jsonData).toLowerCase();",
              "    pm.test('Finish session marks session as completed or finished', function () {",
              "        pm.expect(body.includes('completed') || body.includes('finished')).to.eql(true);",
              "    });",
              "}"
            ]
          }
        }
      ]
    }
  ]
}