{
  "info": {
    "name": "Lab5 Dialog Trainer API Tests",
    "_postman_id": "d1f1b3d4-2a31-4f9a-a7d8-lab5-dialog-trainer-fixed",
    "description": "Fixed Postman collection for Lab 5. Uses environment variables and runs stable API checks.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [],
  "item": [
    {
      "name": "1. Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Health returns 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Health response contains status ok', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Create scenario",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Сценарий для Postman\",\n  \"difficulty\": 2\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/scenarios",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "scenarios"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Create scenario returns 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "var jsonData = pm.response.json();",
              "pm.test('Create scenario returns id', function () {",
              "    pm.expect(jsonData.id).to.exist;",
              "});",
              "pm.environment.set('scenarioId', jsonData.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "3. Get scenario by id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/scenarios/{{scenarioId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "scenarios",
            "{{scenarioId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var scenarioId = pm.environment.get('scenarioId');",
              "if (!scenarioId) {",
              "    throw new Error('scenarioId is empty. Request 2 must run successfully before request 3.');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Get scenario returns 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    pm.test('Returned scenario matches saved id', function () {",
              "        pm.expect(jsonData.id).to.eql(pm.environment.get('scenarioId'));",
              "    });",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "4. Create session",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": {
          "raw": "{{baseUrl}}/sessions",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "sessions"
          ]
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var scenarioId = pm.environment.get('scenarioId');",
              "if (!scenarioId) {",
              "    throw new Error('scenarioId is empty. Request 2 must run successfully before request 4.');",
              "}",
              "var body = {",
              "  userId: 'usr-1',",
              "  scenarioId: scenarioId",
              "};",
              "pm.request.body.raw = JSON.stringify(body, null, 2);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Create session returns 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "var jsonData = pm.response.json();",
              "pm.test('Create session returns id', function () {",
              "    pm.expect(jsonData.id).to.exist;",
              "});",
              "pm.environment.set('sessionId', jsonData.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "5. Get session by id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
